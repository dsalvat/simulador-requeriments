  "framework": "vite",
  "rewrites": [
    { "source": "/api/services-status", "destination": "/api/formations?action=services-status" },
    { "source": "/api/admin/users/:id/organizations", "destination": "/api/admin/users/[id]?sub=organizations" },
    { "source": "/api/admin/users/:id", "destination": "/api/admin/users/[id]" },
    { "source": "/api/admin/sessions/:id", "destination": "/api/admin/sessions/[id]" },
    { "source": "/api/sessions/:id", "destination": "/api/sessions/[id]" }
  ]
}
